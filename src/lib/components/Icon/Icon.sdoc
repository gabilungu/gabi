[SHOWCASE
	title="@components/Icon"
	description="Renders an SVG from the static folder by path. Drawn as a CSS mask, so it takes the current text color and any size — ideal for the monochrome icons in /static/icons."
]

	[preview component={Icon} args={{ path: "/icons/search.svg"}}]
		<Icon {...args} />
	[/preview]

	[example title="The icon set"]
