				>
					<Icon path={`/icons/${name}.svg`} dimension={20} label={name} />
					<span style="font-size: 11px; color: var(--fg-100);">{name}</span>
				</div>
			{/each}
		</div>
	[/example]

	[example title="Dimension (number → px, or any CSS length)"]
		<div style="display: flex; gap: 20px; align-items: flex-end;">
			<Icon path="/icons/folder.svg" dimension={12} />
			<Icon path="/icons/folder.svg" dimension={16} />
			<Icon path="/icons/folder.svg" dimension={24} />
			<Icon path="/icons/folder.svg" dimension="2em" />
			<Icon path="/icons/folder.svg" dimension="48px" />
		</div>
	[/example]

	[example title="Color follows the text"]
		<div style="display: flex; gap: 20px; align-items: center;">
			<span style="color: var(--fg);"
				><Icon path="/icons/info.svg" dimension={22} /></span
