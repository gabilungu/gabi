	]
		<Container width="hug" padding={12} gap={8} radius={8} --border="1px solid var(--base-100)">
			<Placeholder text="a" width="hug" />
			<Placeholder text="b" width="hug" />
			<Placeholder text="c" width="hug" />
		</Container>
		<Container flexDirection="row" width="hug" padding={12} gap={8} radius={8} --border="1px solid var(--base-100)">
			<Placeholder text="a" width="hug" />
			<Placeholder text="b" width="hug" />
			<Placeholder text="c" width="hug" />
		</Container>
	[/example]

	[example
		title="Sizing"
		description="`width`/`height` take `hug` (fit content), `fill` (100%), a number (px), or any CSS length."
		direction="column"
		maxWidth="360px"
	]
		<Container width="hug" padding={12} radius={8} --border="1px solid var(--base-100)">
			<Placeholder width="hug" text="hug — shrinks to content" />
		</Container>
		<Container width="fill" padding={12} radius={8} --border="1px solid var(--base-100)">
			<Placeholder text="fill — spans the row" />
		</Container>
	[/example]

	[example
		title="Border & radius"
		description="`--border` is a full border shorthand; `radius` is a number (px) or any CSS length."
	]
		<Container width={120} height={80} radius={4} --border="1px solid var(--base-300)" />
		<Container width={120} height={80} radius={12} --border="2px solid var(--action-400)" />
		<Container width={120} height={80} radius="50%" --border="1px dashed var(--base-400)" />
	[/example]

	[example
		title="Background"
		description="`--bg` is a background shorthand: a palette colour, or an image with its own sizing and position."
	]
		<Container width={200} height={120} radius={10} --bg="var(--action-100)" />
		<Container width={200} height={120} radius={10} overflow="hidden" --bg="url(/placeholder.png) center / cover no-repeat" />
	[/example]

	[example
		title="Shadow"
		description="`--shadow` takes any box-shadow value."
		gap="24px"
		background="var(--base-100)"
	]
		<Container width={120} height={80} radius={8} --bg="var(--base-0)" --shadow="0 1px 2px rgb(0 0 0 / 0.08)" />
		<Container width={120} height={80} radius={8} --bg="var(--base-0)" --shadow="0 4px 12px rgb(0 0 0 / 0.12)" />
		<Container width={120} height={80} radius={8} --bg="var(--base-0)" --shadow="0 12px 32px rgb(0 0 0 / 0.18)" />
	[/example]

	[example
		title="Overflow"
		description="A fixed height plus `overflow` set to `scrollY` scrolls the content and clips it to the corner radius."
